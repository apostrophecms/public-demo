{
  "name": "public-demo",
  "version": "1.0.0",
  "description": "Apostrophe Public Demo Site",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "node app",
    "dev": "nodemon --delay 1000ms -x \"nodemon app.js\"",
    "migrate": "NODE_ENV=production node app @apostrophecms/migration:migrate",
    "build": "NODE_ENV=production node app @apostrophecms/asset:build",
    "serve": "NODE_ENV=production node app"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "@apostrophecms/blog": "^1.0.6",
    "@apostrophecms/favicon": "^1.1.3",
    "@apostrophecms/import-export": "^3.6.0",
    "@apostrophecms/open-graph": "^1.2.3",
    "@apostrophecms/seo": "^1.2.3",
    "@apostrophecms/vite": "^1.1.0",
    "apostrophe": "^4.24.1",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "klona": "^2.0.6"
  },
  "author": "Apostrophe Technologies, Inc",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "nodemonConfig": {
    "verbose": true,
    "watch": [
      "./app.js",
      "./modules/**/*",
      "./lib/**/*.js",
      "./views/**/*.html",
      "./src/**/*"
    ],
    "ignoreRoot": [
      ".git"
    ],
    "ignore": [
      "./modules/**/ui/*",
      "lib/modules/*/public/js/*.js",
      "locales/*.json",
      "public/uploads",
      "public/apos-frontend",
      "modules/asset/ui/public",
      "data"
    ],
    "ext": "json, js, html, scss, vue"
  },
  "devDependencies": {
    "eslint": "^7.32.0",
    "eslint-config-apostrophe": "^3.4.0",
    "eslint-plugin-node": "^11.1.0",
    "nodemon": "^3.1.14"
  }
}
